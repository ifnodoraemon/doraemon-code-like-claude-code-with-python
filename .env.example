# Code Agent Environment Variables
# Copy this file to .env and fill in your actual API keys
#
# Two modes are supported:
#   1. Direct Mode - You provide API keys for each provider
#   2. Gateway Mode - Connect to a Model Gateway server
#
# The system auto-detects mode: if AGENT_GATEWAY_URL is set, use Gateway mode

# ============================================================
# MODE 1: Direct API Access (Default for individual users)
# ============================================================
# Configure API keys for providers you want to use.
# Model routing is automatic based on model name prefix:
#   gemini-* → Google
#   gpt-*, o1, o3 → OpenAI  
#   claude-* → Anthropic

# Google Gemini API Key
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your_google_api_key_here"

# OpenAI API Key (Optional)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY="your_openai_api_key_here"

# Anthropic API Key (Optional)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Model selection now lives in .agent/config.json
# Example:
# {
#   "model": "gemini-3-pro-preview"
# }

# ============================================================
# MODE 2: Gateway Mode (Recommended for teams/enterprise)
# ============================================================
# Connect to a centralized Model Gateway server.
# Benefits:
#   - Single URL + Key configuration
#   - Centralized API key management
#   - Unified billing and monitoring
#   - Access to all providers without individual keys
#
# To enable Gateway mode, uncomment and configure:

# AGENT_GATEWAY_URL="http://your-gateway-server:8000"
# AGENT_API_KEY="your_gateway_api_key"
# AGENT_GATEWAY_TIMEOUT="120"

# ============================================================
# GATEWAY SERVER Configuration
# (Only needed if you're RUNNING the gateway server)
# ============================================================
# Copy this section to the server's .env file

# Provider API Keys (server-side)
# GOOGLE_API_KEY="server_google_api_key"
# OPENAI_API_KEY="server_openai_api_key"
# ANTHROPIC_API_KEY="server_anthropic_api_key"

# Gateway server settings
# GATEWAY_HOST="0.0.0.0"
# GATEWAY_PORT="8000"
# AGENT_GATEWAY_KEY="key_to_give_to_users"

# ============================================================
# Common Configuration
# ============================================================

# Web UI Authentication (Recommended for production)
# When set, all API endpoints require this key as Bearer token
# AGENT_WEBUI_API_KEY="your_webui_api_key"

# Web UI CORS Origins (comma-separated, optional)
# AGENT_WEBUI_CORS_ORIGINS="http://localhost:5173,http://localhost:8000"

# Gateway: Allow unauthenticated access when no API key is set (NOT recommended for production)
# AGENT_GATEWAY_ALLOW_NO_KEY="1"

# Budget Limits (Optional)
AGENT_DAILY_BUDGET=""     # Daily limit in USD (e.g., "10.00")
AGENT_SESSION_BUDGET=""   # Per-session limit in USD (e.g., "5.00")

# Logging
AGENT_LOG_LEVEL="INFO"
