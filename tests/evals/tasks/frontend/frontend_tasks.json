  {
    "id": "frontend-react-001",
    "name": "Create React Functional Component",
    "category": "frontend_development",
    "difficulty": "easy",
    "prompt": "Create a React functional component in `components/UserCard.tsx` that displays user information (name, email, avatar). Use TypeScript interfaces for props and include proper prop types.",
    "expected_tools": ["write_file"],
    "expected_steps": 1,
    "timeout": 120,
    "assertions": [
      {"type": "file_exists", "path": "components/UserCard.tsx"},
      {"type": "file_contains", "path": "components/UserCard.tsx", "pattern": "interface.*Props|type.*Props"},
      {"type": "file_contains", "path": "components/UserCard.tsx", "pattern": "const UserCard"},
      {"type": "file_contains", "path": "components/UserCard.tsx", "pattern": "export"},
      {"type": "file_contains", "path": "components/UserCard.tsx", "pattern": "name|email|avatar"},
      {"type": "tool_used", "tool": "write_file"}
    ],
    "rubric": {
      "typescript": "Should use proper TypeScript types",
      "component_structure": "Should follow React best practices",
      "props": "Should have well-defined prop types"
    }
  },
