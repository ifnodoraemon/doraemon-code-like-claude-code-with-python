    "id": "api-rest-001",
    "name": "Implement REST API Client",
    "category": "api_integration",
    "difficulty": "medium",
    "prompt": "Create a Python REST API client class in `api_client.py` that can make GET, POST, PUT, DELETE requests to any endpoint. Include proper headers handling, JSON serialization, and timeout configuration.",
    "expected_tools": ["write_file"],
    "expected_steps": 1,
    "timeout": 120,
    "assertions": [
      {"type": "file_exists", "path": "api_client.py"},
      {"type": "file_contains", "path": "api_client.py", "pattern": "class.*Client"},
      {"type": "file_contains", "path": "api_client.py", "pattern": "def get"},
      {"type": "file_contains", "path": "api_client.py", "pattern": "def post"},
      {"type": "file_contains", "path": "api_client.py", "pattern": "def put"},
      {"type": "file_contains", "path": "api_client.py", "pattern": "def delete"},
      {"type": "file_contains", "path": "api_client.py", "pattern": "timeout"},
      {"type": "tool_used", "tool": "write_file"}
    ],
    "rubric": {
      "completeness": "All HTTP methods should be implemented",
      "error_handling": "Should handle network errors gracefully",
      "configurability": "Should support custom headers and timeout"
    }
  },
