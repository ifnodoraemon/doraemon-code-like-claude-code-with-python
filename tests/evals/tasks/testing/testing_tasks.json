    "id": "test-unit-001",
    "name": "Write Unit Tests for Calculator Class",
    "category": "test_writing",
    "difficulty": "easy",
    "prompt": "Write comprehensive unit tests in `tests/test_calculator.py` for a Calculator class with add, subtract, multiply, divide methods. Include tests for normal cases, edge cases (zero, negative numbers), and error cases (division by zero).",
    "expected_tools": ["write_file"],
    "expected_steps": 1,
    "timeout": 150,
    "assertions": [
      {"type": "file_exists", "path": "tests/test_calculator.py"},
      {"type": "file_contains", "path": "tests/test_calculator.py", "pattern": "import pytest|from pytest"},
      {"type": "file_contains", "path": "tests/test_calculator.py", "pattern": "def test_add"},
      {"type": "file_contains", "path": "tests/test_calculator.py", "pattern": "def test_subtract"},
      {"type": "file_contains", "path": "tests/test_calculator.py", "pattern": "def test_multiply"},
      {"type": "file_contains", "path": "tests/test_calculator.py", "pattern": "def test_divide"},
      {"type": "file_contains", "path": "tests/test_calculator.py", "pattern": "ZeroDivisionError|raises"},
      {"type": "tool_used", "tool": "write_file"}
    ],
    "rubric": {
      "coverage": "Should test all methods",
      "edge_cases": "Should include edge case tests",
      "error_handling": "Should test error conditions"
    }
  },
