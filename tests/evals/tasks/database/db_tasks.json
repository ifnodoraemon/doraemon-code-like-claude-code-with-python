    "id": "db-query-001",
    "name": "Write Complex SQL Query with Joins",
    "category": "database_operations",
    "difficulty": "medium",
    "prompt": "Write a SQL query in `queries/user_orders.sql` that retrieves all users with their total order count and total spending. Join the users, orders, and order_items tables. Include users with no orders (show 0).",
    "expected_tools": ["write_file"],
    "expected_steps": 1,
    "timeout": 120,
    "assertions": [
      {"type": "file_exists", "path": "queries/user_orders.sql"},
      {"type": "file_contains", "path": "queries/user_orders.sql", "pattern": "SELECT"},
      {"type": "file_contains", "path": "queries/user_orders.sql", "pattern": "JOIN|join"},
      {"type": "file_contains", "path": "queries/user_orders.sql", "pattern": "LEFT|left"},
      {"type": "file_contains", "path": "queries/user_orders.sql", "pattern": "COUNT|count|SUM|sum"},
      {"type": "file_contains", "path": "queries/user_orders.sql", "pattern": "GROUP BY|group by"},
      {"type": "tool_used", "tool": "write_file"}
    ],
    "rubric": {
      "correctness": "Query should return correct results",
      "efficiency": "Should use appropriate join types",
      "completeness": "Should handle users with no orders"
    }
  },
